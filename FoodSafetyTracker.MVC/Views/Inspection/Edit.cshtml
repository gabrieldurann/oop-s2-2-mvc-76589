@model FoodSafetyTracker.Domain.Entities.Inspection

@{
    ViewData["Title"] = "Edit Inspection";
}

<h1>Edit Inspection</h1>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="PremisesId" class="form-label">Premises</label>
        <select asp-for="PremisesId" class="form-select">
            @foreach (var premises in ViewBag.Premises as IEnumerable<FoodSafetyTracker.Domain.Entities.Premises> ?? [])
            {
                <option value="@premises.Id">@premises.Name - @premises.Town</option>
            }
        </select>
        <span asp-validation-for="PremisesId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="InspectionDate" class="form-label"></label>
        <input asp-for="InspectionDate" type="date" class="form-control" />
        <span asp-validation-for="InspectionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Score" class="form-label"></label>
        <input asp-for="Score" type="number" min="0" max="100" class="form-control" />
        <span asp-validation-for="Score" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Outcome" class="form-label"></label>
        <select asp-for="Outcome" class="form-select"
                asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Domain.Entities.Enums.InspectionOutcome>()">
        </select>
        <span asp-validation-for="Outcome" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>