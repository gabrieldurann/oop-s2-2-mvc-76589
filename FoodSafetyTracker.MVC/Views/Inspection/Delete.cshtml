@model FoodSafetyTracker.Domain.Entities.Inspection

@{
    ViewData["Title"] = "Delete Inspection";
}

<h1>Delete Inspection</h1>

<p class="text-danger">Are you sure you want to delete this inspection?</p>

<dl class="row">
    <dt class="col-sm-3">Premises</dt>
    <dd class="col-sm-9">@Model.Premises?.Name</dd>

    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.InspectionDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Score</dt>
    <dd class="col-sm-9">@Model.Score</dd>

    <dt class="col-sm-3">Outcome</dt>
    <dd class="col-sm-9">@Model.Outcome</dd>

    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>