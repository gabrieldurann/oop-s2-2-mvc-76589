@model FoodSafetyTracker.Domain.Entities.Premises

@{
    ViewData["Title"] = "Edit Premises";
}

<h1>Edit Premises</h1>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
        <span asp-validation-for="Address" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Town" class="form-label"></label>
        <input asp-for="Town" class="form-control" />
        <span asp-validation-for="Town" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RiskRating" class="form-label"></label>
        <select asp-for="RiskRating" class="form-select"
                asp-items="Html.GetEnumSelectList<FoodSafetyTracker.Domain.Entities.Enums.RiskRating>()">
        </select>
        <span asp-validation-for="RiskRating" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>