@model FoodSafetyTracker.Domain.Entities.FollowUp

@{
    ViewData["Title"] = "Follow-Up Details";
}

<h1>Follow-Up Details</h1>

<dl class="row">
    <dt class="col-sm-3">Inspection</dt>
    <dd class="col-sm-9">@Model.Inspection?.InspectionDate.ToShortDateString() - @Model.Inspection?.Premises?.Name</dd>

    <dt class="col-sm-3">Due Date</dt>
    <dd class="col-sm-9">@Model.DueDate.ToShortDateString()</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Closed Date</dt>
    <dd class="col-sm-9">@(Model.ClosedDate?.ToShortDateString() ?? "N/A")</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Back to List</a>
@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    @if (Model.Status == FoodSafetyTracker.Domain.Entities.Enums.FollowUpStatus.Open)
    {
        <a asp-action="Close" asp-route-id="@Model.Id" class="btn btn-success">Close Follow-Up</a>
    }
}