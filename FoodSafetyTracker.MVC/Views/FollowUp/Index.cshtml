@model IEnumerable<FoodSafetyTracker.Domain.Entities.FollowUp>

@{
    ViewData["Title"] = "Follow-Ups";
}

<h1>Follow-Ups</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">Add New Follow-Up</a>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Inspection</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Inspection?.InspectionDate.ToShortDateString() - @item.Inspection?.Premises?.Name</td>
                <td>
                    @item.DueDate.ToShortDateString()
                    @if (item.Status == FoodSafetyTracker.Domain.Entities.Enums.FollowUpStatus.Open && item.DueDate < DateTime.Today)
                    {
                        <span class="badge bg-danger">Overdue</span>
                    }
                </td>
                <td>
                    <span class="badge @(item.Status == FoodSafetyTracker.Domain.Entities.Enums.FollowUpStatus.Open ? "bg-warning" : "bg-success")">
                        @item.Status
                    </span>
                </td>
                <td>@(item.ClosedDate?.ToShortDateString() ?? "N/A")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
                    {
                        @if (item.Status == FoodSafetyTracker.Domain.Entities.Enums.FollowUpStatus.Open)
                        {
                            <a asp-action="Close" asp-route-id="@item.Id" class="btn btn-sm btn-success">Close</a>
                        }
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>